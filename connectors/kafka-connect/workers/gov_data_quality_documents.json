{
    "auto.offset.reset": "earliest",
    "behavior.on.null.values": "DELETE",
    "connection.password": "${file:/tmp/aurelius/env:CONFIG_ELASTIC_PASSWORD}",
    "connection.url": "${file:/tmp/aurelius/env:CONFIG_ELASTIC_URL}",
    "connection.username": "${file:/tmp/aurelius/env:CONFIG_ELASTIC_USERNAME}",
    "connector.class": "io.confluent.connect.elasticsearch.ElasticsearchSinkConnector",
    "elastic.https.ssl.key.password": "${file:/tmp/aurelius/env:CONFIG_ELASTIC_KEY_PASSWORD}",
    "elastic.https.ssl.keystore.location": "/home/appuser/elastic.jks",
    "elastic.https.ssl.keystore.password": "${file:/tmp/aurelius/env:CONFIG_ELASTIC_KEYSTORE_PASSWORD}",
    "elastic.https.ssl.keystore.type": "JKS",
    "elastic.https.ssl.protocol": "TLS",
    "elastic.https.ssl.truststore.location": "/home/appuser/elastic.jks",
    "elastic.https.ssl.truststore.password": "${file:/tmp/aurelius/env:CONFIG_ELASTIC_TRUSTSTORE_PASSWORD}",
    "elastic.https.ssl.truststore.type": "JKS",
    "elastic.security.protocol": "SSL",
    "key.converter": "org.apache.kafka.connect.json.JsonConverter",
    "key.converter.schemas.enable": "false",
    "schema.ignore": "true",
    "tasks.max": "1",
    "topics": "${file:/tmp/aurelius/env:CONFIG_GOV_DATA_QUALITY_KAFKA_TOPIC}",
    "transforms": "ExtractDocId, ExtractValue",
    "transforms.ExtractDocId.field": "id",
    "transforms.ExtractDocId.type": "org.apache.kafka.connect.transforms.ExtractField$Key",
    "transforms.ExtractValue.field": "value",
    "transforms.ExtractValue.type": "org.apache.kafka.connect.transforms.ExtractField$Value",
    "type.name": "_doc",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false"
}
