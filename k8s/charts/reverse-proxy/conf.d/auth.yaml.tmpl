<Location /{{ .Release.Namespace }}/auth/>
ProxyPass "http://keycloak.{{ .Release.Namespace }}.svc.cluster.local:8080/{{ .Release.Namespace }}/auth/"
ProxyPassReverse "http://keycloak.{{ .Release.Namespace }}.svc.cluster.local:8080/{{ .Release.Namespace }}/auth/"
</Location>

# make this configurable to disable access to the admin interface via switch in values
#
<Location /{{ .Release.Namespace }}/auth/admin/>
ProxyPass "http://keycloak.{{ .Release.Namespace }}.svc.cluster.local:8080/{{ .Release.Namespace }}/auth/admin/"
ProxyPassReverse "http://keycloak.{{ .Release.Namespace }}.svc.cluster.local:8080/{{ .Release.Namespace }}/auth/admin/"
</Location>

# NOTE: /atlas/auth/ alias removed — it conflicted with the Alias directive in atlas.yaml
# (Apache Alias covers /atlas/* at the filesystem level; ProxyPass on a sub-path within
# an Alias-mapped space causes 503). The Atlas frontend must use /<namespace>/auth/ directly.
