{
    "ignorePatterns": ["**/*"],
    "overrides": [
        {
            "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
            "rules": {
                "@nx/enforce-module-boundaries": [
                    "error",
                    {
                        "allow": [],
                        "depConstraints": [
                            {
                                "onlyDependOnLibsWithTags": ["*"],
                                "sourceTag": "*"
                            }
                        ],
                        "enforceBuildableLibDependency": true
                    }
                ]
            }
        },
        {
            "extends": ["plugin:@nx/typescript"],
            "files": ["*.ts", "*.tsx"],
            "rules": {}
        },
        {
            "extends": ["plugin:@nx/javascript"],
            "files": ["*.js", "*.jsx"],
            "rules": {}
        },
        {
            "env": {
                "jest": true
            },
            "files": ["*.spec.ts", "*.spec.tsx", "*.spec.js", "*.spec.jsx"],
            "rules": {}
        }
    ],
    "plugins": ["@nx"],
    "root": true
}
