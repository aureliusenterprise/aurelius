{
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "name": "storybook",
    "projectType": "library",
    "tags": [],
    "targets": {
        "build-storybook": {
            "configurations": {
                "ci": {
                    "quiet": true
                }
            },
            "executor": "@storybook/angular:build-storybook",
            "options": {
                "browserTarget": "storybook:build-storybook",
                "compodoc": true,
                "compodocArgs": [
                    "-e json",
                    "--disableSourceCode",
                    "--disableDomTree",
                    "--disableTemplateTab",
                    "--disableStyleTab",
                    "--disableGraph",
                    "--disableCoverage",
                    "--disableRoutesGraph",
                    "--disableSearch",
                    "--disableDependencies",
                    "--disableLifeCycleHooks",
                    "--disablePrivate"
                ],
                "configDir": "libs/storybook/.storybook",
                "outputDir": "dist/storybook/storybook",
                "styles": ["libs/storybook/storybook.scss"]
            },
            "outputs": ["{options.outputPath}"]
        },
        "storybook": {
            "configurations": {
                "ci": {
                    "quiet": true
                }
            },
            "executor": "@storybook/angular:start-storybook",
            "options": {
                "browserTarget": "storybook:build-storybook",
                "compodoc": true,
                "compodocArgs": [
                    "-e json",
                    "--disableSourceCode",
                    "--disableDomTree",
                    "--disableTemplateTab",
                    "--disableStyleTab",
                    "--disableGraph",
                    "--disableCoverage",
                    "--disableRoutesGraph",
                    "--disableSearch",
                    "--disableDependencies",
                    "--disableLifeCycleHooks"
                ],
                "configDir": "libs/storybook/.storybook",
                "port": 4400,
                "styles": ["libs/storybook/storybook.scss"]
            }
        }
    }
}
