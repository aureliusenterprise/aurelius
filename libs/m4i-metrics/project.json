{
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "name": "m4i-metrics",
    "projectType": "library",
    "sourceRoot": "libs/m4i-metrics/m4i_metrics",
    "tags": [],
    "targets": {
        "add": {
            "executor": "@nxlv/python:add",
            "options": {}
        },
        "build": {
            "executor": "@nxlv/python:build",
            "options": {
                "bundleLocalDependencies": true,
                "lockedVersions": true,
                "outputPath": "dist/libs/m4i-metrics",
                "publish": false
            },
            "outputs": ["{workspaceRoot}/dist/{projectRoot}"]
        },
        "lint": {
            "executor": "@nxlv/python:ruff-check",
            "options": {
                "lintFilePatterns": ["m4i_metrics", "tests"]
            },
            "outputs": []
        },
        "remove": {
            "executor": "@nxlv/python:remove",
            "options": {}
        },
        "test": {
            "executor": "@nxlv/python:run-commands",
            "options": {
                "command": "poetry run pytest tests/",
                "cwd": "libs/m4i-metrics"
            },
            "outputs": [
                "{workspaceRoot}/reports/libs/m4i-metrics/unittests",
                "{workspaceRoot}/coverage/libs/m4i-metrics"
            ]
        },
        "update": {
            "executor": "@nxlv/python:update",
            "options": {}
        }
    }
}
